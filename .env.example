# Copy to .env and fill in the providers you actually use.
# honeyprompt reads keys from the environment; they are never stored in honeyprompt.yaml.

# Docker image to deploy. Pin a release tag in production, for example 0.1.0.
HONEYPROMPT_IMAGE=alectrocute/honeyprompt:latest

# LLM provider API keys (only set the ones you enable in honeyprompt.yaml)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=

# Local runtimes
OLLAMA_URL=http://localhost:11434/v1

# Web panel basic-auth password (plaintext; honeyprompt handles the rest)
HONEYPROMPT_PANEL_PASSWORD=changeme
