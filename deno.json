{
  "name": "honeyprompt",
  "version": "0.1.6",
  "exports": "./src/main.ts",
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --allow-ffi src/main.ts",
    "dev": "deno run --watch --allow-net --allow-read --allow-write --allow-env --allow-ffi src/main.ts",
    "check": "deno check src/main.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "compile": "deno compile --allow-net --allow-read --allow-write --allow-env --allow-ffi --output dist/honeyprompt src/main.ts"
  },
  "imports": {
    "@std/yaml": "jsr:@std/yaml@1.1.2",
    "@std/assert": "jsr:@std/assert@1.0.14",
    "ssh2": "npm:ssh2@1.17.0"
  },
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  },
  "exclude": [
    "dist/",
    "node_modules/"
  ]
}
